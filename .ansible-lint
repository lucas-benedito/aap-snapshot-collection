---
profile: production
rulesdir:
  - rules/
exclude_paths:
  - changelogs
  - .github
  - scripts
  - docs
  - tests/integration
  - tests/unit
  # auto-generated directories
  - extensions/molecule
  - .ansible
enable_list:
  - custom-no-log
  - custom-loop-control
  - custom-play-boilerplate
warn_list:
  - no-log-password
